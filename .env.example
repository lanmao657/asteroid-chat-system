OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MODEL_PROVIDER=openai

# Agent 运行参数
# 这部分控制对话上下文长度、单次输出长度，以及长对话时的摘要压缩策略。
# 一般本地开发可以直接使用默认值，只有在回答过长或上下文不够时再调整。
AGENT_COMPOSE_INPUT_CHAR_BUDGET=4200
AGENT_CONVERSATION_WINDOW=6
AGENT_COMPOSE_OUTPUT_TOKEN_LIMIT=700
AGENT_MAX_CONTINUATIONS=2
AGENT_CONTINUATION_TAIL_CHARS=1000
AGENT_SUMMARY_TRIGGER_MESSAGES=8
AGENT_SUMMARY_RECENT_WINDOW=4

# 实时网页搜索
# 最小可用配置：
# 1. 至少填写下面一个主搜索服务的 API Key。
# 2. 建议按推荐顺序保留 SEARCH_PROVIDERS。
# 3. 对“今天 / 最新 / 新闻”这类请求，强烈建议启用 Tavily 或 Search API。
# 4. `.env.example` 只是模板，真实 Key 请填写到 `.env.local`。
TAVILY_API_BASE_URL=https://api.tavily.com/search
TAVILY_API_KEY=
SEARCH_API_BASE_URL=https://google.serper.dev/search
SEARCH_API_KEY=
# 每次搜索最终最多保留多少条候选结果。
SEARCH_MAX_RESULTS=5
# 单条网页搜索结果摘要的最大字符数，避免上下文过长。
WEB_SEARCH_CONTENT_MAX_CHARS=420
# 推荐的最小搜索链路：
SEARCH_PROVIDERS=tavily,search-api,bing-rss
# 如果你的网络可以稳定访问 DuckDuckGo HTML，可以启用这个可选兜底：
# SEARCH_PROVIDERS=tavily,search-api,duckduckgo-html,bing-rss
# 这里可以填需要屏蔽的域名，多个域名用逗号分隔。
SEARCH_BLOCKED_DOMAINS=
# 这里可以填需要降权的域名，多个域名用逗号分隔。
SEARCH_DEMOTED_DOMAINS=zhihu.com,baidu.com,tieba.baidu.com
# 搜索命中后，最多进一步抓取多少个网页正文。
FETCH_MAX_PAGES=3
# 搜索请求和网页抓取的超时时间，单位毫秒。
WEB_FETCH_TIMEOUT_MS=12000

# 知识库 / 重排
# 这部分用于“本地知识库检索”，不是联网搜索的主链路。
# 如果你只是想查实时新闻，这部分可以先保持默认。
# KNOWLEDGE_BASE_MAX_RESULTS 表示知识库检索时最多保留多少条候选文档。
KNOWLEDGE_BASE_MAX_RESULTS=4
# JINA_API_KEY 是可选项。填写后会调用 Jina 对知识库候选结果做二次重排。
JINA_API_KEY=
# 使用的 Jina 重排模型，默认这个多语言模型适合中英文场景。
JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual

# 天气
# 天气查询服务地址，默认使用 wttr.in。
WEATHER_API_BASE_URL=https://wttr.in

# 数据库
# 这部分用于把运行日志持久化到 PostgreSQL。
# 如果本地没有数据库，应用主体仍可运行，只是不会保存聊天运行日志。
DATABASE_URL=postgresql://lanmao:550695@localhost:5432/mydb
DATABASE_MAX_CONNECTIONS=5
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
